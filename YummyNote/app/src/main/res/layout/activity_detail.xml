<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/main_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/header_bg"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📋  맛집 상세 정보"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Main Info Card -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/card_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="기본 정보"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/main_point"
                        android:layout_marginBottom="10dp" />

                    <EditText
                        android:id="@+id/edtName"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_edittext_rounded"
                        android:hint="🍴  맛집 이름"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:singleLine="true"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary" />

                    <EditText
                        android:id="@+id/edtCategory"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_edittext_rounded"
                        android:hint="🍽️  음식 종류"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:singleLine="true"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary" />

                    <EditText
                        android:id="@+id/edtAddress"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_edittext_rounded"
                        android:hint="📍  주소"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:singleLine="true"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp">

                        <EditText
                            android:id="@+id/edtPrice"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/bg_edittext_rounded"
                            android:hint="💰 가격"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:inputType="number"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary" />

                        <EditText
                            android:id="@+id/edtRating"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:background="@drawable/bg_edittext_rounded"
                            android:hint="⭐ 별점"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:inputType="number"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Memo Card -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/card_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="리뷰 메모"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/main_point"
                        android:layout_marginBottom="10dp" />

                    <EditText
                        android:id="@+id/edtMemo"
                        android:layout_width="match_parent"
                        android:layout_height="110dp"
                        android:background="@drawable/bg_edittext_rounded"
                        android:gravity="top|start"
                        android:hint="리뷰 메모"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="10dp"
                        android:inputType="textMultiLine"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Location Card -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/card_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="위치 좌표"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/main_point"
                        android:layout_marginBottom="10dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/edtLat"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/bg_edittext_rounded"
                            android:hint="위도"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:inputType="numberDecimal|numberSigned"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary" />

                        <EditText
                            android:id="@+id/edtLng"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:background="@drawable/bg_edittext_rounded"
                            android:hint="경도"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:inputType="numberDecimal|numberSigned"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnMap"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_button_secondary"
                        android:text="🗺️  지도에서 보기"
                        android:textColor="@color/main_point"
                        android:textSize="14sp"
                        android:stateListAnimator="@null" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Action Buttons -->
            <Button
                android:id="@+id/btnUpdate"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_button_add"
                android:text="✏️  수정하기"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btnDelete"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_button_danger"
                android:text="🗑️  삭제"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btnBack"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_button_secondary"
                android:text="← 목록으로"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:stateListAnimator="@null" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
